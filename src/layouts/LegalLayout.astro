---
import MainLayout from "./MainLayout.astro";

const { title, description } = Astro.props;
---

<MainLayout title={title} description={description} robots={true}>
  <section class="px-6 pt-32 pb-24" style="border-bottom: 1px solid var(--border);">
    <article class="legal mx-auto">
      <slot />
    </article>
  </section>
</MainLayout>

<style is:global>
  .legal {
    max-width: 720px;
    color: var(--text);
    font-size: 16px;
    line-height: 1.75;
  }
  .legal h1 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: clamp(2.25rem, 4vw, 3rem);
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: var(--text);
  }
  .legal h2 {
    font-family: 'Instrument Serif', serif;
    font-weight: 400;
    font-size: 1.5rem;
    line-height: 1.25;
    margin-top: 3rem;
    margin-bottom: 1rem;
    color: var(--text);
  }
  .legal h3 {
    font-weight: 500;
    font-size: 1rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }
  .legal p {
    margin-bottom: 1.25rem;
    color: var(--text);
    opacity: 0.85;
  }
  .legal p.last-updated {
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 3rem;
  }
  .legal a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .legal a:hover {
    color: var(--text);
  }
  .legal ul, .legal ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
    color: var(--text);
    opacity: 0.85;
  }
  .legal ul { list-style: disc; }
  .legal ol { list-style: decimal; }
  .legal li {
    margin-bottom: 0.5rem;
  }
  .legal strong {
    color: var(--text);
    font-weight: 500;
    opacity: 1;
  }
  .legal table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
  }
  .legal th, .legal td {
    text-align: left;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    opacity: 0.85;
  }
  .legal th {
    font-weight: 500;
    color: var(--text);
    opacity: 1;
    border-bottom: 1px solid var(--border-strong);
  }
  .legal hr {
    border: 0;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }
</style>
