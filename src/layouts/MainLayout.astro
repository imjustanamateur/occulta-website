---
import Footer from "../components/ui/Footer.astro";
import Navbar from "../components/ui/Navbar.astro";
import MainHead from "./MainHead.astro";
import "../styles/global.css";

const { ...props } = Astro.props;
---

<html lang="en">
  <MainHead {...props} />
  <style>
    html.lenis { height: auto; }
    .lenis.lenis-smooth { scroll-behavior: auto; }
    .lenis.lenis-smooth [data-lenis-prevent] { overscroll-behavior: contain; }
    .lenis.lenis-stopped { overflow: hidden; }

    /* Custom cursor */
    #cursor-dot {
      position: fixed; top: 0; left: 0;
      width: 6px; height: 6px; border-radius: 50%;
      background: #E8E4DC;
      pointer-events: none; z-index: 9999;
      transform: translate(-50%, -50%);
      opacity: 0; will-change: transform;
    }
    #cursor-ring {
      position: fixed; top: 0; left: 0;
      width: 32px; height: 32px; border-radius: 50%;
      border: 1px solid rgba(232, 228, 220, 0.35);
      pointer-events: none; z-index: 9998;
      transform: translate(-50%, -50%);
      opacity: 0; will-change: transform;
    }

    /* Spotlight overlay */
    #spotlight-overlay {
      position: fixed; inset: 0;
      pointer-events: none; z-index: 0;
      opacity: 0;
      background: radial-gradient(
        700px circle at var(--spot-x, 50%) var(--spot-y, 50%),
        rgba(232, 228, 220, 0.04) 0%,
        transparent 65%
      );
      transition: opacity 0.6s ease;
      will-change: background;
    }
  </style>

  <script src="../utils/lenis"></script>

  <body style="background-color: var(--bg); color: var(--text); font-family: 'Inter', system-ui, sans-serif;">
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-NVJ4SFLH"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->

    <!-- Spotlight -->
    <div id="spotlight-overlay" aria-hidden="true"></div>

    <!-- Custom cursor (hidden on touch) -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true"></div>

    <main>
      <Navbar />
      <slot />
      <Footer />
    </main>
  </body>

  <script is:inline>
    /* ── DATALAYER TRACKING ── */
    window.dataLayer = window.dataLayer || [];

    // 1. Page view
    window.dataLayer.push({
      event: 'page_view',
      page_title: document.title,
      page_path: window.location.pathname,
      page_type: 'homepage'
    });

    // 2. Scroll depth — fires once at 25 / 50 / 75 / 100%
    (function () {
      var depths = [25, 50, 75, 100];
      var fired = {};
      window.addEventListener('scroll', function () {
        var pct = Math.round((window.scrollY + window.innerHeight) / document.body.scrollHeight * 100);
        depths.forEach(function (d) {
          if (pct >= d && !fired[d]) {
            fired[d] = true;
            window.dataLayer.push({ event: 'scroll_depth', depth_percent: d });
          }
        });
      }, { passive: true });
    })();

    // 3. Section view — fires once per section when 30% visible
    (function () {
      var sectionIds = ['services', 'process', 'contact'];
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) {
            window.dataLayer.push({ event: 'section_view', section_id: e.target.id });
            io.unobserve(e.target);
          }
        });
      }, { threshold: 0.3 });
      sectionIds.forEach(function (id) {
        var el = document.getElementById(id);
        if (el) io.observe(el);
      });
    })();

    // 4. CTA clicks — hero + navbar "Get in touch" / "Start the conversation"
    document.addEventListener('click', function (e) {
      var target = e.target.closest('a[href="#contact"], a[href="/#contact"]');
      if (!target) return;
      var loc = target.closest('nav') ? 'navbar' : target.closest('#home') ? 'hero' : 'other';
      window.dataLayer.push({
        event: 'cta_click',
        cta_text: target.textContent.trim(),
        cta_location: loc,
        cta_type: loc === 'navbar' ? 'nav' : 'primary'
      });
    });

    // 5. Nav link clicks (Services, Process — excludes contact handled above)
    document.addEventListener('click', function (e) {
      var target = e.target.closest('nav a');
      if (!target) return;
      var href = target.getAttribute('href') || '';
      if (href.indexOf('#contact') !== -1) return; // already tracked as cta_click
      window.dataLayer.push({
        event: 'nav_click',
        nav_label: target.textContent.trim(),
        nav_destination: href
      });
    });
  </script>

  <script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { SplitText } from "gsap/SplitText";

    gsap.registerPlugin(ScrollTrigger, SplitText);

    /* ── ONE-TIME EFFECTS (pointer devices only) ── */
    const isPointer = window.matchMedia("(pointer: fine)").matches;

    if (isPointer) {
      document.body.style.cursor = "none";

      const dot  = document.getElementById("cursor-dot")!;
      const ring = document.getElementById("cursor-ring")!;
      const spotlight = document.getElementById("spotlight-overlay")!;

      // Cursor – dot tracks exactly, ring lags
      const dotX  = gsap.quickTo(dot,  "x", { duration: 0.05 });
      const dotY  = gsap.quickTo(dot,  "y", { duration: 0.05 });
      const ringX = gsap.quickTo(ring, "x", { duration: 0.38, ease: "power3.out" });
      const ringY = gsap.quickTo(ring, "y", { duration: 0.38, ease: "power3.out" });

      // Hero parallax layers
      const heroEl = document.querySelector("#home");
      type Layer = { xTo: (v: number) => void; yTo: (v: number) => void; depth: number };
      let layers: Layer[] = [];
      if (heroEl) {
        layers = Array.from(heroEl.querySelectorAll<HTMLElement>("[data-depth]")).map((el) => ({
          xTo: gsap.quickTo(el, "x", { duration: 0.9, ease: "power3.out" }),
          yTo: gsap.quickTo(el, "y", { duration: 0.9, ease: "power3.out" }),
          depth: parseFloat(el.dataset.depth ?? "0"),
        }));
      }

      let cursorVisible = false;

      window.addEventListener("mousemove", (e) => {
        // Cursor
        dotX(e.clientX); dotY(e.clientY);
        ringX(e.clientX); ringY(e.clientY);

        // Spotlight – direct CSS var, GPU handles gradient
        spotlight.style.setProperty("--spot-x", e.clientX + "px");
        spotlight.style.setProperty("--spot-y", e.clientY + "px");

        if (!cursorVisible) {
          cursorVisible = true;
          gsap.to([dot, ring], { opacity: 1, duration: 0.4 });
          spotlight.style.opacity = "1";
        }

        // Hero parallax
        const cx = window.innerWidth / 2;
        const cy = window.innerHeight / 2;
        layers.forEach(({ xTo, yTo, depth }) => {
          xTo((e.clientX - cx) * depth);
          yTo((e.clientY - cy) * depth);
        });
      });

      // Ring expands on links/buttons
      document.querySelectorAll("a, button").forEach((el) => {
        el.addEventListener("mouseenter", () =>
          gsap.to(ring, { scale: 1.8, borderColor: "rgba(232,228,220,0.65)", duration: 0.25 }));
        el.addEventListener("mouseleave", () =>
          gsap.to(ring, { scale: 1, borderColor: "rgba(232,228,220,0.35)", duration: 0.25 }));
      });

      // Magnetic CTA button
      document.querySelectorAll<HTMLElement>(".magnetic-btn").forEach((btn) => {
        const bx = gsap.quickTo(btn, "x", { duration: 0.45, ease: "power3.out" });
        const by = gsap.quickTo(btn, "y", { duration: 0.45, ease: "power3.out" });
        btn.addEventListener("mousemove", (e) => {
          const r = btn.getBoundingClientRect();
          bx((e.clientX - r.left - r.width  / 2) * 0.38);
          by((e.clientY - r.top  - r.height / 2) * 0.38);
        });
        btn.addEventListener("mouseleave", () => { bx(0); by(0); });
      });
    }

    /* ── PAGE LOAD + SCROLL ANIMATIONS ── */
    function initAnimations() {
      // Hero heading — word-by-word reveal
      const heading = document.querySelector<HTMLElement>(".hero-heading");
      if (heading) {
        const split = new SplitText(heading, { type: "words" });
        gsap.set(split.words, { y: 56, opacity: 0 });
        gsap.to(split.words, {
          y: 0, opacity: 1,
          duration: 1.0, stagger: 0.07, ease: "power3.out", delay: 0.1,
        });
      }

      // Hero subtitle + CTA cascade
      const sub = document.querySelector(".hero-sub");
      const cta = document.querySelector(".hero-cta");
      if (sub) { gsap.set(sub, { y: 18, opacity: 0 }); gsap.to(sub, { y: 0, opacity: 1, duration: 0.8, ease: "power2.out", delay: 0.72 }); }
      if (cta) { gsap.set(cta, { y: 14, opacity: 0 }); gsap.to(cta, { y: 0, opacity: 1, duration: 0.7, ease: "power2.out", delay: 0.95 }); }

      // Scroll reveals
      gsap.utils.toArray<HTMLElement>(".reveal").forEach((el) => {
        gsap.from(el, {
          scrollTrigger: { trigger: el, start: "top 88%", once: true },
          y: 32, opacity: 0, duration: 0.85, ease: "power2.out",
        });
      });

      // Stagger grids
      gsap.utils.toArray<HTMLElement>(".reveal-group").forEach((group) => {
        gsap.from(Array.from(group.children) as HTMLElement[], {
          scrollTrigger: { trigger: group, start: "top 88%", once: true },
          y: 24, opacity: 0, duration: 0.7, stagger: 0.08, ease: "power2.out",
        });
      });
    }

    initAnimations();
    document.addEventListener("astro:after-swap", () => {
      ScrollTrigger.getAll().forEach((t) => t.kill());
      initAnimations();
    });
  </script>
</html>
