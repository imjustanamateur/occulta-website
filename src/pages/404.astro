---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Page Not Found — Occulta"
  description="The page you're looking for doesn't exist."
>
  <div
    class="flex flex-col items-start justify-center min-h-[70vh] px-6 md:px-16 lg:px-24"
    style="border-bottom: 1px solid var(--border);"
  >
    <p
      class="text-xs uppercase tracking-[0.25em] mb-8"
      style="color: var(--accent);"
    >
      404
    </p>
    <h1
      class="font-serif font-normal leading-[1.05] mb-8"
      style="font-size: clamp(2.5rem, 6vw, 5rem); color: var(--text);"
    >
      This page doesn't<br />
      <em class="italic" style="color: var(--text-muted);">exist.</em>
    </h1>
    <p
      class="text-base leading-relaxed mb-12 max-w-sm"
      style="color: var(--text-muted);"
    >
      The page you're looking for has moved or was never here.
    </p>
    <a href="/" class="btn-primary">Back to home</a>
  </div>
</MainLayout>
