---
import Section from "./Section.astro";
---

<Section id="home">
  <div class="pt-40 pb-20 md:pt-52 md:pb-28" style="border-bottom: 1px solid var(--border);">

    <!-- Label -->
    <div class="section-label mb-12" style="color: var(--accent);">
      <span class="text-xs uppercase tracking-[0.2em]">Strategy Consulting</span>
    </div>

    <!-- Headline -->
    <h1
      class="hero-heading font-serif font-normal leading-[1.04] mb-12"
      style="font-size: clamp(3rem, 7.5vw, 6.5rem); color: var(--text);"
    >
      Strategy isn't<br />
      a plan.<br />
      <em class="italic" style="color: var(--accent);">It's a choice.</em>
    </h1>

    <!-- Subtitle + CTA row -->
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-10">
      <p
        class="hero-sub text-base md:text-lg leading-relaxed max-w-md"
        style="color: var(--text-muted);"
      >
        Occulta uncovers the hidden dynamics shaping your market, challenges
        the assumptions keeping you stuck, and builds the strategy your
        business needs to win.
      </p>
      <div class="hero-cta shrink-0">
        <a href="#contact" class="btn-primary">Start the conversation</a>
      </div>
    </div>

  </div>
</Section>
