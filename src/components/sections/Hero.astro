---
import Section from "./Section.astro";
import { Image } from "astro:assets";
import HeroIlust from "../../assets/pics/hero.svg";
---

<Section id="home">
<div class="relative flex flex-col-reverse items-center md:flex-row" id="hero">
    <div class="row items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <div class="text-left space-y-3">
            <h1 class="text-4xl font-medium leading-none md:text-6xl text-center md:text-left">Strategy isn't <br> a plan. <br> <span style="color: #C8A86B;">It's a choice.</span></h1>
            <p class="mt-6 mb-8 text-lg font-normal leading-7 sm:mb-12 text-center md:text-left md:pr-12" style="color: #AAAAAA;">Occulta uncovers the hidden dynamics shaping your market, challenges the assumptions keeping you stuck, and builds the strategy your business needs to win.</p>
            <div class="w-full justify-center md:justify-start items-center inline-flex">
                <a href="#contact" class="px-8 py-5 rounded-2xl text-center text-[#C8A86B] border border-[#C8A86B] hover:bg-[#C8A86B] hover:text-black transition-all duration-200 text-xl font-normal leading-7">Start the conversation
                </a>
            </div>
        </div>
    </div>
    <div class="flex items-center py-5 md:w-6/12 md:pb-20 md:pt-10">
        <Image src={HeroIlust} alt="Hero Ilustration" loading="eager" />
    </div>
</div>
</Section>