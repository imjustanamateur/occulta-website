---
import SectionTitle from "../ui/SectionTitle.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import Section from "./Section.astro";

import c1 from "../../assets/pics/card-pic1.png";
import c2 from "../../assets/pics/card-pic2.png";
import c3 from "../../assets/pics/card-pic3.png";
import c4 from "../../assets/pics/card-pic4.png";
import c5 from "../../assets/pics/card-pic5.png";
import c6 from "../../assets/pics/card-pic6.png";

const cards = [
  { seq: 1, titleTop: "Strategic",  titleBottom: "Diagnosis",      link: "#contact" },
  { seq: 2, titleTop: "Strategy",   titleBottom: "Design",          link: "#contact" },
  { seq: 3, titleTop: "Market",     titleBottom: "Intelligence",    link: "#contact" },
  { seq: 4, titleTop: "Hypothesis", titleBottom: "Testing",         link: "#contact" },
  { seq: 5, titleTop: "Strategic",  titleBottom: "Narrative",       link: "#contact" },
  { seq: 6, titleTop: "Advisory &", titleBottom: "Accountability",  link: "#contact" },
];

const description =
  "Consulting that starts with the right questions, not predetermined answers. Every engagement is built around your specific challenge.";
---

<Section id="services">
  <div class="mt-[140px] mb-5">
    <SectionTitle sectionTitle="Services" description={description} />
    <div class="grid lg:grid-cols-2 gap-4 reveal-group">
      {
        cards.map((card) => (
          <ServiceCard
            seq={card.seq}
            titleTop={card.titleTop}
            titleBottom={card.titleBottom}
            link={card.link}
          />
        ))
      }
    </div>
  </div>
</Section>
