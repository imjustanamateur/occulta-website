---
import SectionTitle from "../ui/SectionTitle.astro";
import ServiceCard from "../ui/ServiceCard.astro";
import Section from "./Section.astro";

const cards = [
  {
    seq: 1,
    title: "Strategy",
    description: "The integrated set of choices that determines where you compete and how you win. Not a plan. Not a list of goals. A clear theory of competitive advantage, built to be tested and acted on.",
    link: "#contact"
  },
  {
    seq: 2,
    title: "Brand",
    description: "The mental structures that make you the obvious choice before the purchase decision begins. Positioning, narrative, and the distinctive assets that create pricing power over time.",
    link: "#contact"
  },
  {
    seq: 3,
    title: "Marketing",
    description: "The activation of your strategy in market. Advertising, CRM & email, and the measurement and analytics to know what's actually working — and what isn't.",
    link: "#contact"
  },
];

const description =
  "Strategy, brand, and marketing built as one integrated system — not three separate briefs.";
---

<Section id="services">
  <div class="mt-[140px] mb-5">
    <SectionTitle sectionTitle="Services" description={description} />
    <div class="grid lg:grid-cols-3 gap-4 reveal-group">
      {
        cards.map((card) => (
          <ServiceCard
            seq={card.seq}
            title={card.title}
            description={card.description}
            link={card.link}
          />
        ))
      }
    </div>
  </div>
</Section>
