---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

import propImg from "../../assets/pics/proposal-pic.png";
---

<Section>
  <Card>
    <div
      class="flex rounded-[45px] p-[60px] relative mt-[123px] mb-[163px]" style="background-color: #141414; border: 1px solid #2A2A2A;"
    >
      <div class="w-full md:w-[40%] flex flex-col gap-[26px]">
        <h2 class="text-3xl font-medium">Your strategy is waiting to be found.</h2>
        <p style="color: #AAAAAA;">
          Most businesses are solving the wrong problems. The strategy you need isn't hidden in more data or better execution — it starts with asking the right questions.
        </p>
        <a href="#contact" class="btn-primary">Start the conversation</a>
      </div>
      <picture
        class="hidden md:flex absolute right-[-10%] lg:right-0 top-[-15%] h-[450px] items-center justify-center"
      >
        <Image
          src={propImg}
          alt="This is an illustration"
          class="hidden md:flex lg:h-full lg:w-auto"
        />
      </picture>
    </div>
  </Card>
</Section>
