---
import Section from "./Section.astro";
---

<Section>
  <div class="py-24 reveal" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between gap-12">

      <div class="space-y-5 max-w-2xl">
        <p class="section-label text-xs uppercase tracking-[0.2em]" style="color: var(--accent);">
          Let's work together
        </p>
        <h2
          class="font-serif font-normal leading-[1.08]"
          style="font-size: clamp(2rem, 5vw, 4rem); color: var(--text);"
        >
          Your strategy is<br />waiting to be found.
        </h2>
        <p class="text-base leading-relaxed max-w-md" style="color: var(--text-muted);">
          Most businesses are solving the wrong problems. The strategy you need
          starts with asking the right questions — not adding more activity.
        </p>
      </div>

      <div class="shrink-0">
        <a href="#contact" class="btn-primary">Start the conversation</a>
      </div>

    </div>
  </div>
</Section>
