---
const { sectionTitle, description } = Astro.props;
---

<div class="mb-14 reveal">
  <div class="section-label" style="color: var(--accent);">
    <span class="text-xs uppercase tracking-[0.2em]">{sectionTitle}</span>
  </div>
  <p class="text-base md:text-lg max-w-xl leading-relaxed" style="color: var(--text-muted);">
    {description}
  </p>
</div>
