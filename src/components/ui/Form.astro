---
---

<div
  class="p-8 md:p-12 rounded-2xl reveal"
  style="background-color: var(--surface); border: 1px solid var(--border);"
>
  <form class="w-full max-w-xl space-y-6" name="contact" method="POST" data-netlify="true" action="/thank-you">

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="space-y-2">
        <label for="name" class="block text-xs uppercase tracking-[0.15em]" style="color: var(--text-muted);">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Your name"
          class="w-full px-5 py-4 rounded-lg text-sm outline-none transition-colors duration-200"
          style="background-color: var(--surface-2); border: 1px solid var(--border); color: var(--text);"
        />
      </div>

      <div class="space-y-2">
        <label for="email" class="block text-xs uppercase tracking-[0.15em]" style="color: var(--text-muted);">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="your@email.com"
          class="w-full px-5 py-4 rounded-lg text-sm outline-none transition-colors duration-200"
          style="background-color: var(--surface-2); border: 1px solid var(--border); color: var(--text);"
        />
      </div>
    </div>

    <div class="space-y-2">
      <label for="message" class="block text-xs uppercase tracking-[0.15em]" style="color: var(--text-muted);">What's the challenge?</label>
      <textarea
        id="message"
        name="message"
        rows="5"
        placeholder="Describe what you're facing — the more specific, the better."
        class="w-full px-5 py-4 rounded-lg text-sm outline-none resize-none transition-colors duration-200"
        style="background-color: var(--surface-2); border: 1px solid var(--border); color: var(--text);"
      ></textarea>
    </div>

    <button type="submit" class="btn-primary">Send message</button>

  </form>
</div>

<script is:inline>
  (function () {
    var form = document.querySelector('form[name="contact"]');
    if (!form) return;
    window.dataLayer = window.dataLayer || [];

    // form_start — fires on first field focus
    var started = false;
    form.querySelectorAll('input, textarea').forEach(function (field) {
      field.addEventListener('focus', function () {
        if (started) return;
        started = true;
        window.dataLayer.push({ event: 'form_start', form_name: 'contact' });
      });
    });

    // form_submit — fires on submit with field fill status
    form.addEventListener('submit', function () {
      window.dataLayer.push({
        event: 'form_submit',
        form_name: 'contact',
        has_name: !!(form.querySelector('#name') || {}).value,
        has_email: !!(form.querySelector('#email') || {}).value,
        has_message: !!(form.querySelector('#message') || {}).value
      });
    });
  })();
</script>

<style>
  input:focus, textarea:focus {
    border-color: var(--accent) !important;
  }
  input::placeholder, textarea::placeholder {
    color: var(--text-muted);
    opacity: 0.6;
  }
</style>
