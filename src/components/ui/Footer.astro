---
import { Image } from "astro:assets";
import Linkedin from "../../assets/linkedin.svg";
---

<footer style="border-top: 1px solid var(--border); background-color: var(--bg);">
  <div class="w-full max-w-[1280px] mx-auto px-5 py-16">

    <div class="flex flex-col md:flex-row justify-between gap-12 mb-16">

      <!-- Brand -->
      <div class="space-y-4 max-w-xs">
        <p class="text-sm uppercase tracking-[0.2em]" style="color: var(--text);">OCCULTA</p>
        <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
          Strategy consulting that starts with the right questions. Not the comfortable ones.
        </p>
      </div>

      <!-- Nav -->
      <div class="flex flex-col gap-3">
        <p class="text-xs uppercase tracking-[0.15em] mb-2" style="color: var(--text-muted);">Navigate</p>
        {[
          { name: "Services", href: "#services" },
          { name: "Process",  href: "#process"  },
          { name: "Contact",  href: "#contact"  },
        ].map((link) => (
          <a
            href={link.href}
            class="text-sm transition-colors duration-200"
            style="color: var(--text-muted);"
            onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'"
          >
            {link.name}
          </a>
        ))}
      </div>

      <!-- Contact -->
      <div class="space-y-3">
        <p class="text-xs uppercase tracking-[0.15em] mb-2" style="color: var(--text-muted);">Contact</p>
        <a
          href="mailto:joaobarbosa@occulta.co"
          class="text-sm transition-colors duration-200 block"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'"
        >
          joaobarbosa@occulta.co
        </a>
        <a
          href="https://linkedin.com/in/joao-barbosa-"
          target="_blank"
          class="text-sm transition-colors duration-200 flex items-center gap-2"
          style="color: var(--text-muted);"
          onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-muted)'"
        >
          <Image src={Linkedin} alt="LinkedIn" class="w-4 h-4 opacity-60" />
          LinkedIn
        </a>
      </div>

    </div>

    <div class="flex flex-col md:flex-row justify-between items-center gap-4 pt-8" style="border-top: 1px solid var(--border);">
      <p class="text-xs" style="color: var(--text-muted);">© 2025 Occulta</p>
      <p class="text-xs" style="color: var(--text-muted); opacity: 0.5;">Strategy. Uncovered.</p>
    </div>

  </div>
</footer>
