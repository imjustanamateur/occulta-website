---
const { seq, titleTop, titleBottom, link } = Astro.props;
const num = String(seq).padStart(2, "0");
---

<a
  href={link}
  class="service-card group block p-8 md:p-10 rounded-2xl transition-all duration-300"
  style="background-color: var(--surface); border: 1px solid var(--border);"
>
  <div class="flex flex-col min-h-[200px] justify-between">

    <!-- Number -->
    <span
      class="font-serif italic leading-none select-none"
      style="font-size: clamp(2.5rem, 5vw, 4rem); color: var(--text-muted); opacity: 0.35;"
    >
      {num}
    </span>

    <!-- Title + arrow row -->
    <div class="flex items-end justify-between gap-4">
      <h3 class="text-2xl md:text-3xl font-normal leading-tight" style="color: var(--text);">
        {titleTop}<br />{titleBottom}
      </h3>
      <span
        class="text-lg transition-transform duration-300 group-hover:translate-x-1"
        style="color: var(--accent); opacity: 0; transition: opacity 0.2s, transform 0.3s;"
        data-arrow
      >→</span>
    </div>

  </div>
</a>

<style>
  .service-card:hover {
    border-color: var(--border-strong);
    background-color: var(--surface-2);
  }
  .service-card:hover [data-arrow] {
    opacity: 1;
  }
</style>
